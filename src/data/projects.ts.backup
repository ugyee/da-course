  {
    id: 18,
    title: "交通流量分析与优化",
    description: "学习分析交通数据，预测流量趋势，优化交通管理策略",
    dataset: {
      filename: "traffic_data.csv",
      fields: [
        { name: "time", meaning: "时间", type: "datetime" },
        { name: "location", meaning: "地点", type: "string" },
        { name: "traffic_volume", meaning: "交通量", type: "int" },
        { name: "average_speed", meaning: "平均速度(km/h)", type: "float" },
        { name: "temperature", meaning: "温度(°C)", type: "float" },
        { name: "weather", meaning: "天气", type: "string" },
        { name: "is_holiday", meaning: "是否节假日", type: "boolean" },
        { name: "day_of_week", meaning: "星期几", type: "int" }
      ],
