    codeTemplate: `import pandas as pd
import numpy as np
import streamlit as st
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟综合数据
np.random.seed(42)
dates = pd.date_range('2024-01-01', periods=12, freq='M')
regions = ['华东', '华南', '华北', '西南', '华中']
products = ['AI写作助手', '代码生成器', '图像生成API', '语音合成', '数据分析平台']
channels = ['线上', '线下']

# 生成销售数据
sales_data = []
for date in dates:
    for region in regions:
        for product in products:
            for channel in channels:
                sales = np.random.randint(5000, 20000)
                profit = sales * 0.3
                customers = np.random.randint(50, 200)
                conversion_rate = np.random.uniform(2.0, 5.0)
                sales_data.append({
                    'date': date,
                    'region': region,
                    'product': product,
                    'channel': channel,
                    'sales': sales,
                    'profit': profit,
                    'customers': customers,
                    'conversion_rate': conversion_rate
                })

sales_df = pd.DataFrame(sales_data)

# 生成客户数据
customer_data = []
for i in range(1, 1001):
    customer_id = f'C{i:04d}'
    recency = np.random.randint(1, 90)
    frequency = np.random.randint(1, 20)
    monetary = np.random.randint(1000, 20000)
    customer_data.append({
        'customer_id': customer_id,
        'recency': recency,
        'frequency': frequency,
        'monetary': monetary
    })

customer_df = pd.DataFrame(customer_data)

# 生成财务数据
financial_data = []
for year in [2020, 2021, 2022, 2023, 2024]:
    for quarter in [1, 2, 3, 4]:
        revenue = np.random.randint(1000000, 3000000)
        net_income = revenue * 0.15
        total_assets = revenue * 2.5
        total_liabilities = total_assets * 0.6
        financial_data.append({
            'year': year,
            'quarter': quarter,
            'revenue': revenue,
            'net_income': net_income,
            'total_assets': total_assets,
            'total_liabilities': total_liabilities
        })

financial_df = pd.DataFrame(financial_data)

# Streamlit仪表盘
print("=== 综合商务智能仪表盘 ===")
print("\n仪表盘功能:")
print("1. 首页：企业经营概览")
print("2. 销售分析模块")
print("3. 客户分析模块")
print("4. 产品分析模块")
print("5. 财务分析模块")

# 首页概览数据
total_sales = sales_df['sales'].sum()
total_profit = sales_df['profit'].sum()
total_customers = sales_df['customers'].sum()
average_conversion = sales_df['conversion_rate'].mean()

print("\n=== 企业经营概览 ===")
print(f"总销售额: {total_sales:,.2f}")
print(f"总利润: {total_profit:,.2f}")
print(f"总客户数: {total_customers:,}")
print(f"平均转化率: {average_conversion:.2f}%")

# 销售分析
top_regions = sales_df.groupby('region')['sales'].sum().sort_values(ascending=False).head(3)
top_products = sales_df.groupby('product')['sales'].sum().sort_values(ascending=False).head(3)
top_channels = sales_df.groupby('channel')['sales'].sum()

print("\n=== 销售分析 ===")
print("Top 3 销售地区:")
print(top_regions)
print("\nTop 3 销售产品:")
print(top_products)
print("\n渠道销售分布:")
print(top_channels)

# 客户分析
top_customers = customer_df.nlargest(5, 'monetary')
print("\n=== 客户分析 ===")
print("Top 5 高价值客户:")
print(top_customers)

# 产品分析
product_profit = sales_df.groupby('product')['profit'].sum().sort_values(ascending=False)
print("\n=== 产品分析 ===")
print("产品利润贡献:")
print(product_profit)

# 财务分析
financial_summary = financial_df.groupby('year')['revenue', 'net_income'].sum()
print("\n=== 财务分析 ===")
print("年度财务摘要:")
print(financial_summary)

print("\n=== 仪表盘部署说明 ===")
print("1. 安装依赖: pip install streamlit pandas numpy matplotlib seaborn")
print("2. 保存代码为 dashboard.py")
print("3. 运行: streamlit run dashboard.py")
print("4. 在浏览器中访问 http://localhost:8501")

print("\n=== 个性化定制建议 ===")
print("1. 添加更多数据源和分析维度")
print("2. 集成实时数据更新功能")
print("3. 添加用户权限管理")
print("4. 导出分析报告功能")
print("5. 移动端适配")
