    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime
import re
from collections import Counter

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟社交媒体数据
np.random.seed(42)
n_posts = 1000

# 平台
platforms = ['微博', '微信', '抖音', '知乎', '小红书']

# 产品
products = ['AI写作助手', '代码生成器', '图像生成API', '语音合成', '数据分析平台']

# 积极、消极词汇
positive_words = ['好用', '不错', '惊艳', '推荐', '强大', '喜欢', '棒', '优秀', '完美', '满意']
negative_words = ['bug', '一般', '希望改进', '失望', '差', '不好', '垃圾', '慢', '贵', '卡顿']

# 生成文本模板
text_templates = [
    '这个{product}真的太{adj}了！{comment}',
    '{product}有时候会有{negative}，但总体还{positive}',
    '{product}帮我解决了很多问题，值得推荐！',
    '{product}功能{comment}，希望能改进{improve}',
    '使用{product}一段时间了，感受是{comment}',
    '强烈推荐{product}，{comment}',
    '{product}比我预期的{comment}',
    '今天试了{product}，感觉{comment}',
    '公司里很多人在用{product}，{comment}',
    '对于{product}，我觉得{comment}'
]

# 生成数据
data = []
for i in range(n_posts):
    platform = np.random.choice(platforms, p=[0.3, 0.25, 0.2, 0.15, 0.1])
    product = np.random.choice(products)
    
    # 随机选择模板
    template_idx = np.random.randint(0, len(text_templates))
    template = text_templates[template_idx]
    
    # 确定情感方向
    sentiment_positive = np.random.random() > 0.3
    
    # 填充模板
    if template_idx in [0, 2, 5, 6, 7, 8, 9]:
        if sentiment_positive:
            adj = np.random.choice(positive_words)
            comment = np.random.choice(['提高了我的工作效率', '超出预期', '功能强大', '性价比高'])
            text = template.format(product=product, adj=adj, comment=comment)
        else:
            adj = np.random.choice(negative_words)
            comment = np.random.choice(['还有改进空间', '让人失望', '需要优化', '希望能更好'])
            text = template.format(product=product, adj=adj, comment=comment)
    elif template_idx in [1]:
        if sentiment_positive:
            negative = np.random.choice(['小问题', '不稳定', '偶尔卡顿'])
            positive = np.random.choice(['不错', '可以', '还行', '推荐'])
        else:
            negative = np.random.choice(['bug', '很多问题', '经常崩溃', '太差'])
            positive = np.random.choice(['一般', '不行', '不推荐'])
        text = template.format(product=product, negative=negative, positive=positive)
    else:
        if sentiment_positive:
            comment = np.random.choice(['功能强大', '非常好用', '值得推荐', '超出预期'])
            improve = np.random.choice(['更多功能', '服务', '用户体验', ''])
        else:
            comment = np.random.choice(['功能一般', '需要优化', '希望改进', '不太满意'])
            improve = np.random.choice(['速度', '稳定性', '用户体验', '功能'])
        text = template.format(product=product, comment=comment, improve=improve)
    
    # 生成互动数据
    likes = np.random.randint(10, 300)
    shares = np.random.randint(5, 100)
    comments = np.random.randint(3, 50)
    
    # 生成时间戳
    start_date = datetime(2024, 1, 1)
    timestamp = start_date + pd.Timedelta(days=np.random.randint(0, 30), 
                                           hours=np.random.randint(0, 24),
                                           minutes=np.random.randint(0, 60))
    
    data.append({
        'post_id': f'P{i+1:03d}',
        'platform': platform,
        'text': text,
        'user_id': f'U{np.random.randint(1, 501):03d}',
        'timestamp': timestamp,
        'likes': likes,
        'shares': shares,
        'comments': comments,
        'sentiment': '积极' if sentiment_positive else '消极'
    })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总帖子数: {len(df)}")

# 1. 情感分布
print("\\n=== 1. 情感分布 ===")
sentiment_distribution = df['sentiment'].value_counts(normalize=True)
print("情感分布:")
print(sentiment_distribution)

# 2. 各产品情感分析
print("\\n=== 2. 各产品情感分析 ===")
product_sentiment = pd.crosstab(df['platform'], df['sentiment'], normalize='index')
print("产品情感分析:")
print(product_sentiment)

# 3. 文本分析
print("\\n=== 3. 文本分析 ===")
# 简单词频分析
all_texts = ' '.join(df['text'].tolist())
words = all_texts.split()

# 过滤掉标点符号和停用词
stop_words = ['的', '了', '在', '是', '我', '有', '和', '就', '不', '人', '都', '一', '一个', '上', '也', '很', '到', '说', '要', '去', '你', '会', '着', '没有', '看', '好', '自己', '这']
words = [word for word in words if word not in stop_words and len(word) > 1]

# 词频统计
word_counts = Counter(words)
top_words = word_counts.most_common(20)
print("高频词:")
print([word for word, count in top_words])

# 4. 平台分析
print("\\n=== 4. 平台分析 ===")
platform_performance = df.groupby('platform').agg({
    'likes': 'mean',
    'shares': 'mean',
    'comments': 'mean',
    'post_id': 'count'
}).rename(columns={
    'likes': '平均点赞',
    'shares': '平均分享',
    'comments': '平均评论',
    'post_id': '帖子数'
}).sort_values('帖子数', ascending=False)
print("平台表现:")
print(platform_performance)

# 5. 时间分析
print("\\n=== 5. 时间分析 ===")
df['timestamp'] = pd.to_datetime(df['timestamp'])
df['hour'] = df['timestamp'].dt.hour
df['day_of_week'] = df['timestamp'].dt.dayofweek

# 小时级分布
hourly_distribution = df.groupby('hour')['post_id'].count()
print("小时级分布:")
print(hourly_distribution)

