    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟A/B测试数据
np.random.seed(42)
n_users = 1000

# 分组
group = np.random.choice(['对照组', '实验组'], n_users, p=[0.5, 0.5])

# 转化率
# 对照组转化率10%
# 实验组转化率15%
converted = np.zeros(n_users, dtype=bool)
control_mask = group == '对照组'
test_mask = group == '实验组'

converted[control_mask] = np.random.binomial(1, 0.1, sum(control_mask)).astype(bool)
converted[test_mask] = np.random.binomial(1, 0.15, sum(test_mask)).astype(bool)

# 订单金额
order_value = np.zeros(n_users)
order_value[converted] = np.random.choice([99, 149, 199, 299], sum(converted))

# 会话时长
session_duration = np.zeros(n_users)
session_duration[control_mask] = np.random.normal(120, 30, sum(control_mask))
session_duration[test_mask] = np.random.normal(150, 35, sum(test_mask))
session_duration = session_duration.astype(int)

# 页面浏览量
page_views = np.zeros(n_users, dtype=int)
page_views[control_mask] = np.random.poisson(4, sum(control_mask))
page_views[test_mask] = np.random.poisson(5, sum(test_mask))

# 创建数据集
df = pd.DataFrame({
    'user_id': [f'U{i:03d}' for i in range(1, n_users + 1)],
    'group': group,
    'converted': converted,
    'order_value': order_value,
    'session_duration': session_duration,
    'page_views': page_views
})

print("=== 数据基本信息 ===")
print(df.info())
print("\n数据前5行:")
print(df.head())
print(f"\n总用户数: {len(df)}")
print(f"对照组用户数: {sum(df['group'] == '对照组')}")
print(f"实验组用户数: {sum(df['group'] == '实验组')}")

# 1. 实验数据完整性检查
print("\n=== 1. 实验数据完整性检查 ===")
print("样本量检查:")
print(f"对照组: {sum(df['group'] == '对照组')}")
print(f"实验组: {sum(df['group'] == '实验组')}")
print(f"分组比例: {sum(df['group'] == '对照组')/len(df)*100:.2f}% / {sum(df['group'] == '实验组')/len(df)*100:.2f}%")

# 2. 描述性统计分析
print("\n=== 2. 描述性统计分析 ===")
# 按组统计
print("按组统计:")
group_stats = df.groupby('group').agg({
    'converted': ['count', 'sum', 'mean'],
    'order_value': ['mean', 'median', 'std'],
    'session_duration': ['mean', 'median', 'std'],
    'page_views': ['mean', 'median', 'std']
})

print(group_stats)

# 计算转化率
control_conversion = df[df['group'] == '对照组']['converted'].mean()
test_conversion = df[df['group'] == '实验组']['converted'].mean()
conversion_diff = test_conversion - control_conversion
conversion_lift = (test_conversion - control_conversion) / control_conversion * 100

print(f"\n转化率分析:")
print(f"对照组转化率: {control_conversion*100:.2f}%")
print(f"实验组转化率: {test_conversion*100:.2f}%")
print(f"转化率差异: {conversion_diff*100:.2f}%")
print(f"转化率提升: {conversion_lift:.2f}%")

# 3. 假设检验
print("\n=== 3. 假设检验 ===")

# 3.1 转化率卡方检验
print("3.1 转化率卡方检验:")
contingency_table = pd.crosstab(df['group'], df['converted'])
print("列联表:")
print(contingency_table)

chi2, p_value, dof, expected = stats.chi2_contingency(contingency_table)
print(f"卡方统计量: {chi2:.4f}")
print(f"p值: {p_value:.4f}")
print(f"自由度: {dof}")

if p_value < 0.05:
    print("结论: 两组转化率存在显著差异")
else:
    print("结论: 两组转化率无显著差异")

# 3.2 平均订单金额t检验
print("\n3.2 平均订单金额t检验:")
# 只考虑转化的用户
control_order = df[(df['group'] == '对照组') & (df['converted'])]['order_value']
test_order = df[(df['group'] == '实验组') & (df['converted'])]['order_value']

t_stat, p_value_order = stats.ttest_ind(control_order, test_order, equal_var=False)
print(f"对照组平均订单金额: {control_order.mean():.2f}")
print(f"实验组平均订单金额: {test_order.mean():.2f}")
print(f"t统计量: {t_stat:.4f}")
print(f"p值: {p_value_order:.4f}")

if p_value_order < 0.05:
    print("结论: 两组平均订单金额存在显著差异")
else:
    print("结论: 两组平均订单金额无显著差异")

# 3.3 会话时长t检验
print("\n3.3 会话时长t检验:")
control_duration = df[df['group'] == '对照组']['session_duration']
test_duration = df[df['group'] == '实验组']['session_duration']

t_stat_duration, p_value_duration = stats.ttest_ind(control_duration, test_duration, equal_var=False)
print(f"对照组平均会话时长: {control_duration.mean():.2f}秒")
print(f"实验组平均会话时长: {test_duration.mean():.2f}秒")
print(f"t统计量: {t_stat_duration:.4f}")
print(f"p值: {p_value_duration:.4f}")

if p_value_duration < 0.05:
    print("结论: 两组会话时长存在显著差异")
else:
    print("结论: 两组会话时长无显著差异")

# 4. 统计功效和p值解读
print("\n=== 4. 统计功效和p值解读 ===")
print("p值解读:")
print("- p值 < 0.05: 结果具有统计显著性")
print("- p值越小: 结果越可靠")
print(f"\n转化率检验p值: {p_value:.4f}")
print(f"订单金额检验p值: {p_value_order:.4f}")
print(f"会话时长检验p值: {p_value_duration:.4f}")

# 5. 结论和建议
print("\n=== 5. 结论和建议 ===")
print("A/B测试分析结论:")
print(f"1. 转化率: 实验组({test_conversion*100:.2f}%)显著高于对照组({control_conversion*100:.2f}%)，提升了{conversion_lift:.2f}%")
print(f"2. 平均订单金额: 两组{'存在' if p_value_order < 0.05 else '无'}显著差异")
print(f"3. 会话时长: 实验组({test_duration.mean():.2f}秒)显著高于对照组({control_duration.mean():.2f}秒)")

print("\n建议:")
if p_value < 0.05 and test_conversion > control_conversion:
    print("1. 建议全量上线新版本")
    print("2. 进一步优化页面设计，持续提升转化率")
    print("3. 分析实验组表现更好的具体原因")
else:
    print("1. 建议继续优化新版本")
    print("2. 考虑增加样本量进行进一步测试")
    print("3. 分析用户行为数据，找出改进点")
`
