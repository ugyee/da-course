        ["P001", "AI写作助手", "2024-01-02", "89.0", "35", "True", "1500", "109.0"],
        ["P002", "代码生成器", "2024-01-01", "199.0", "15", "False", "800", "219.0"],
        ["P002", "代码生成器", "2024-01-02", "199.0", "18", "False", "800", "219.0"],
