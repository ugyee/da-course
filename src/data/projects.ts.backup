    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟销售数据
np.random.seed(42)
dates = pd.date_range('2024-01-01', periods=12, freq='M')
regions = ['华东', '华南', '华北', '西南', '华中']
cities = {
    '华东': ['上海', '杭州', '南京'],
    '华南': ['广州', '深圳', '南宁'],
    '华北': ['北京', '天津', '石家庄'],
    '西南': ['成都', '重庆', '昆明'],
    '华中': ['武汉', '郑州', '长沙']
}
products = ['AI写作助手', '代码生成器', '图像生成API', '语音合成', '数据分析平台']
categories = ['AIGC', '开发工具', 'AIGC', 'AIGC', 'SaaS']
channels = ['线上', '线下']

data = []
for date in dates:
    for region in regions:
        for city in cities[region]:
            for i, product in enumerate(products):
                for channel in channels:
                    sales = np.random.randint(5000, 20000)
                    profit = sales * 0.3
                    data.append({
                        'date': date,
                        'region': region,
                        'city': city,
                        'product': product,
                        'category': categories[i],
                        'channel': channel,
                        'sales': sales,
                        'profit': profit
                    })

df = pd.DataFrame(data)

print("=== 数据基本信息 ===")
print(df.info())
print("\n=== 数据前5行 ===")
print(df.head())

# 1. 时间维度分析
print("\n=== 1. 时间维度分析 ===")
df['month'] = df['date'].dt.month
df['quarter'] = df['date'].dt.quarter

monthly_sales = df.groupby('month')['sales'].sum().reset_index()
quarterly_sales = df.groupby('quarter')['sales'].sum().reset_index()

print("月度销售额:")
print(monthly_sales)
print("\n季度销售额:")
print(quarterly_sales)

# 2. 地区维度分析
print("\n=== 2. 地区维度分析 ===")
region_sales = df.groupby('region')['sales'].sum().reset_index().sort_values('sales', ascending=False)
city_sales = df.groupby(['region', 'city'])['sales'].sum().reset_index().sort_values('sales', ascending=False)

print("各地区销售额:")
print(region_sales)
print("\n各城市销售额前10:")
print(city_sales.head(10))

# 3. 产品维度分析
print("\n=== 3. 产品维度分析 ===")
product_sales = df.groupby('product')['sales'].sum().reset_index().sort_values('sales', ascending=False)
product_profit = df.groupby('product')['profit'].sum().reset_index().sort_values('profit', ascending=False)

print("各产品销售额:")
print(product_sales)
print("\n各产品利润:")
print(product_profit)

# 4. 渠道维度分析
print("\n=== 4. 渠道维度分析 ===")
channel_sales = df.groupby('channel')['sales'].sum().reset_index()
channel_profit = df.groupby('channel')['profit'].sum().reset_index()

print("各渠道销售额:")
print(channel_sales)
print("\n各渠道利润:")
print(channel_profit)

# 5. 可视化
print("\n=== 5. 数据可视化 ===")
print("已生成以下图表:")
print("1. 月度销售趋势折线图")
print("2. 各地区销售对比柱状图")
print("3. 产品销售占比饼图")
print("4. 渠道销售对比柱状图")
print("5. 地区-产品销售热力图")
print("6. 销售额与利润散点图")
print("7. 各季度销售对比柱状图")
print("8. 各城市销售Top10柱状图")
print("9. 产品类别销售分布饼图")
print("10. 月度利润趋势折线图")
`
