    description: "学习分析产品价格与销量的关系，确定价格弹性，优化产品定价策略",
    dataset: {
      filename: "product_price_sensitivity.csv",
      fields: [
        { name: "product_id", meaning: "产品ID", type: "string" },
        { name: "product_name", meaning: "产品名称", type: "string" },
        { name: "date", meaning: "日期", type: "datetime" },
