    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from statsmodels.tsa.holtwinters import SimpleExpSmoothing, Holt, ExponentialSmoothing
from statsmodels.tsa.arima.model import ARIMA
from sklearn.metrics import mean_absolute_error, mean_squared_error

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟过去3年的月度销售数据
np.random.seed(42)
dates = pd.date_range('2021-01-01', periods=36, freq='M')

# 创建趋势、季节性和噪声
trend = np.linspace(10000, 25000, 36)
seasonality = 5000 * np.sin(np.linspace(0, 6 * np.pi, 36))
noise = np.random.normal(0, 1000, 36)

# 添加促销活动的影响
promotion = np.random.choice([True, False], 36, p=[0.3, 0.7])
promotion_effect = np.where(promotion, 3000, 0)

sales = trend + seasonality + noise + promotion_effect
products = (sales / 120).astype(int)

df = pd.DataFrame({
    'date': dates,
    'sales': sales,
    'products': products,
    'promotion': promotion
})

print("=== 销售数据 ===")
print(df.head())
print(f"\n数据时间范围: {df['date'].min()} 到 {df['date'].max()}")

# 可视化历史销售数据
print("\n=== 历史销售趋势 ===")
plt.figure(figsize=(12, 6))
plt.plot(df['date'], df['sales'], marker='o')
plt.title('历史销售趋势')
plt.xlabel('日期')
plt.ylabel('销售额')
plt.grid(True)
plt.show()

# 划分训练集和测试集
train_size = int(len(df) * 0.8)
train, test = df[:train_size], df[train_size:]
print(f"\n训练集大小: {len(train)}, 测试集大小: {len(test)}")

# 1. 移动平均法
print("\n=== 1. 移动平均法 ===")
df['MA3'] = df['sales'].rolling(window=3).mean()
df['MA6'] = df['sales'].rolling(window=6).mean()

print("移动平均结果:")
print(df[['date', 'sales', 'MA3', 'MA6']].tail())

# 2. 指数平滑法
print("\n=== 2. 指数平滑法 ===")

# 简单指数平滑
print("2.1 简单指数平滑:")
ses_model = SimpleExpSmoothing(train['sales']).fit(smoothing_level=0.2)
ses_forecast = ses_model.forecast(len(test))

# 霍尔特指数平滑
print("2.2 霍尔特指数平滑:")
holt_model = Holt(train['sales']).fit(smoothing_level=0.2, smoothing_trend=0.2)
holt_forecast = holt_model.forecast(len(test))

# 霍尔特-温特斯指数平滑
print("2.3 霍尔特-温特斯指数平滑:")
hw_model = ExponentialSmoothing(train['sales'], 
                                trend='add', 
                                seasonal='add', 
                                seasonal_periods=12).fit()
hw_forecast = hw_model.forecast(len(test))

# 3. ARIMA模型
print("\n=== 3. ARIMA模型 ===")
try:
    arima_model = ARIMA(train['sales'], order=(1, 1, 1)).fit()
    arima_forecast = arima_model.forecast(len(test))
    print("ARIMA模型拟合成功")
except Exception as e:
    print(f"ARIMA模型拟合失败: {e}")
    arima_forecast = np.zeros(len(test))

# 模型评估
print("\n=== 模型评估 ===")
models = {
    '简单指数平滑': ses_forecast,
    '霍尔特指数平滑': holt_forecast,
    '霍尔特-温特斯': hw_forecast,
    'ARIMA': arima_forecast
}

for model_name, forecast in models.items():
    mae = mean_absolute_error(test['sales'], forecast)
    mse = mean_squared_error(test['sales'], forecast)
    rmse = np.sqrt(mse)
    mape = np.mean(np.abs((test['sales'] - forecast) / test['sales'])) * 100
    
    print(f"\n{model_name}:")
    print(f"MAE: {mae:.2f}")
    print(f"MSE: {mse:.2f}")
    print(f"RMSE: {rmse:.2f}")
    print(f"MAPE: {mape:.2f}%")

# 选择最优模型进行未来预测
print("\n=== 未来6个月销售预测 ===")
# 使用霍尔特-温特斯模型进行预测
future_dates = pd.date_range(df['date'].max() + pd.Timedelta(days=1), periods=6, freq='M')
future_forecast = hw_model.forecast(6)

print("未来6个月预测结果:")
for date, pred in zip(future_dates, future_forecast):
    print(f"{date.strftime('%Y-%m-%d')}: {pred:.2f}")

# 可视化预测结果
print("\n=== 预测结果可视化 ===")
plt.figure(figsize=(14, 7))
plt.plot(train['date'], train['sales'], label='历史数据')
plt.plot(test['date'], test['sales'], label='测试数据')
plt.plot(test['date'], hw_forecast, label='霍尔特-温特斯预测')
plt.plot(future_dates, future_forecast, label='未来预测', linestyle='--')
plt.title('销售预测')
plt.xlabel('日期')
plt.ylabel('销售额')
plt.legend()
plt.grid(True)
plt.show()

print("\n=== 分析总结 ===")
print("1. 时间序列分析显示销售额具有明显的趋势和季节性")
print("2. 促销活动对销售额有显著影响")
print("3. 霍尔特-温特斯模型考虑了趋势和季节性，预测效果较好")
print("4. 预测的局限性：市场变化、竞争环境、外部因素等可能影响预测准确性")
