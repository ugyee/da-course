import numpy as np

# 模拟包含常见数据问题的销售数据
data = {
    'order_id': ['ORD001', 'ORD002', 'ORD003', 'ORD004', 'ORD005', 'ORD006', 'ORD007', 'ORD008', 'ORD009', 'ORD010'],
    'date': ['2024-01-01', '2024-01-02', '2024-01-03', '2024-01-04', '2024-01-05', '2024-01-06', '2024-01-07', '2024-01-08', '2024-01-09', '2024-01-10'],
    'product': ['AI写作助手', '代码生成器', '图像生成API', '语音合成', '数据分析平台', np.nan, 'AI写作助手', '代码生成器', '图像生成API', '语音合成'],
    'category': ['AIGC', '开发工具', 'AIGC', 'AIGC', 'SaaS', 'AIGC', 'AIGC', '开发工具', 'AIGC', 'AIGC'],
    'region': ['华东', '华南', '华北', '华东', '华南', '华东', '华东', '华南', '华北', '华东'],
    'quantity': [2, 1, 5, 3, 1, 4, 2, 1, 5, 3],
    'price': [99.0, 199.0, 49.0, 79.0, 299.0, 59.0, 99.0, 199.0, 49.0, 79.0],
    'sales': [198.0, 199.0, 245.0, 237.0, 299.0, 236.0, 198.0, 199.0, 245.0, 237.0]
}

# 读取数据
df = pd.DataFrame(data)

print("=== 原始数据 ===")
print(df)
print("\n=== 数据基本信息 ===")
print(df.info())
print("\n=== 统计摘要 ===")
print(df.describe())

# 1. 缺失值处理
print("\n=== 1. 缺失值处理 ===")
print("缺失值情况:")
print(df.isnull().sum())

# 2. 重复值检测与删除
print("\n=== 2. 重复值检测与删除 ===")
print(f"重复行数: {df.duplicated().sum()}")
df = df.drop_duplicates()
print(f"删除重复后行数: {len(df)}")

# 3. 异常值识别与处理
print("\n=== 3. 异常值识别与处理 ===")
# 使用IQR方法检测异常值
Q1 = df['sales'].quantile(0.25)
Q3 = df['sales'].quantile(0.75)
IQR = Q3 - Q1
lower_bound = Q1 - 1.5 * IQR
upper_bound = Q3 + 1.5 * IQR

outliers = df[(df['sales'] < lower_bound) | (df['sales'] > upper_bound)]
print(f"异常值: {len(outliers)}个")
print(outliers)

# 4. 数据类型转换
print("\n=== 4. 数据类型转换 ===")
df['date'] = pd.to_datetime(df['date'])
df['quantity'] = df['quantity'].astype(int)
print("数据类型:")
print(df.dtypes)

# 5. 数据标准化与归一化
print("\n=== 5. 数据标准化与归一化 ===")
from sklearn.preprocessing import StandardScaler, MinMaxScaler

scaler = StandardScaler()
df['sales_standardized'] = scaler.fit_transform(df[['sales']])

minmax_scaler = MinMaxScaler()
df['sales_normalized'] = minmax_scaler.fit_transform(df[['sales']])

print("标准化和归一化后:")
print(df[['sales', 'sales_standardized', 'sales_normalized']].head())

print("\n=== 清洗后的数据 ===")
print(df)
`
