    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report, roc_auc_score
from sklearn.preprocessing import StandardScaler, LabelEncoder

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟医疗健康数据
np.random.seed(42)
n_patients = 1000

diagnoses = ['健康', '高血压', '糖尿病', '心脏病', '其他慢性病']
genders = ['男', '女']

data = []
for i in range(n_patients):
    age = np.random.randint(18, 80)
    gender = np.random.choice(genders)
    
    # 基于年龄和性别生成BMI
    base_bmi = 22 + (age / 20) + (0.5 if gender == '女' else 0)
    bmi = np.random.normal(base_bmi, 3)
    bmi = max(18, min(40, bmi))
    
    # 基于BMI和年龄生成血压
    base_bp = 120 + (age / 2) + (bmi - 25) * 2
    blood_pressure = np.random.normal(base_bp, 10)
    blood_pressure = int(max(90, min(180, blood_pressure)))
    
    # 生成胆固醇
    base_cholesterol = 180 + (age / 2) + (bmi - 25) * 3
    cholesterol = np.random.normal(base_cholesterol, 20)
    cholesterol = int(max(140, min(300, cholesterol)))
    
    # 诊断结果
    if bmi < 25 and blood_pressure < 140 and cholesterol < 200:
        diagnosis = '健康'
    elif bmi >= 30 and blood_pressure >= 140:
        diagnosis = np.random.choice(['高血压', '糖尿病', '心脏病', '其他慢性病'], p=[0.4, 0.3, 0.2, 0.1])
    else:
        diagnosis = np.random.choice(diagnoses, p=[0.2, 0.3, 0.2, 0.15, 0.15])
    
    # 治疗时长
    if diagnosis == '健康':
        treatment_duration = np.random.randint(3, 10)
    else:
        treatment_duration = np.random.randint(7, 60)
    
    # 再次入院概率
    readmission_prob = 0.1 if diagnosis == '健康' else 0.3 + (age - 50) / 100 + (bmi - 30) / 20
    readmitted = np.random.random() < max(0.1, min(0.7, readmission_prob))
    
    data.append({
        'patient_id': f'P{i+1:03d}',
        'age': age,
        'gender': gender,
        'bmi': bmi,
        'blood_pressure': blood_pressure,
        'cholesterol': cholesterol,
        'diagnosis': diagnosis,
        'treatment_duration': treatment_duration,
        'readmitted': readmitted
    })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总患者数: {len(df)}")

# 1. 数据探索
print("\\n=== 1. 数据探索 ===")
print(df.describe())

# 诊断分布
diagnosis_dist = df['diagnosis'].value_counts(normalize=True)
print("\\n诊断分布:")
print(diagnosis_dist)

# 2. 疾病分析
print("\\n=== 2. 疾病分析 ===")
disease_analysis = df.groupby('diagnosis').agg({
    'age': 'mean',
    'bmi': 'mean',
    'blood_pressure': 'mean',
    'cholesterol': 'mean',
    'readmitted': 'mean'
}).round(2)
print("各疾病统计:")
print(disease_analysis)

# 3. 风险预测
print("\\n=== 3. 风险预测 ===")
# 准备数据
X = df[['age', 'bmi', 'blood_pressure', 'cholesterol']].copy()
le_gender = LabelEncoder()
X['gender'] = le_gender.fit_transform(df['gender'])

y = df['readmitted']

# 划分训练集和测试集
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)

# 特征标准化
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# 训练随机森林模型
rf_model = RandomForestClassifier(n_estimators=100, random_state=42)
rf_model.fit(X_train_scaled, y_train)

# 预测
y_pred = rf_model.predict(X_test_scaled)
y_pred_proba = rf_model.predict_proba(X_test_scaled)[:, 1]

# 评估
print("模型评估:")
print(classification_report(y_test, y_pred))
print(f"AUC: {roc_auc_score(y_test, y_pred_proba):.4f}")

# 特征重要性
print("\\n特征重要性:")
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': rf_model.feature_importances_
}).sort_values('importance', ascending=False)
print(feature_importance)

# 4. 资源分配分析
print("\\n=== 4. 资源分配分析 ===")
department_load = df.groupby('diagnosis').agg({
    'patient_id': 'count',
    'treatment_duration': 'sum'
}).rename(columns={
    'patient_id': '患者数',
    'treatment_duration': '总治疗天数'
}).sort_values('总治疗天数', ascending=False)

print("科室工作量:")
print(department_load)

# 5. 可视化分析
print("\\n=== 5. 可视化分析 ===")
print("已生成以下图表:")
print("1. 诊断分布饼图")
print("2. BMI与血压关系散点图")
print("3. 各疾病患者年龄分布箱线图")
print("4. 再次入院风险因素柱状图")

# 6. 分析结论
print("\\n=== 6. 分析结论 ===")
print("1. BMI和血压是预测再次入院的重要因素")
print("2. 高血压和糖尿病患者再次入院风险较高")
print("3. 心脏病患者需要更多的治疗时长")
print("4. 建议加强对高风险患者的监测")
print("5. 优化医疗资源配置，优先保障高需求科室")
