    codeTemplate: `import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
import matplotlib.pyplot as plt
import seaborn as sns

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟客户交易数据
np.random.seed(42)
n_customers = 200
customer_ids = [f'C{i:03d}' for i in range(1, n_customers + 1)]

data = []
for customer_id in customer_ids:
    # 随机生成交易次数
    n_transactions = np.random.randint(1, 20)
    # 最近交易日期
    days_since_last_purchase = np.random.randint(1, 90)
    last_purchase_date = pd.Timestamp('2024-01-31') - pd.Timedelta(days=days_since_last_purchase)
    
    for i in range(n_transactions):
        # 生成交易日期（从最近交易日期往前推）
        transaction_date = last_purchase_date - pd.Timedelta(days=np.random.randint(0, 365))
        transaction_amount = np.random.randint(100, 5000)
        data.append({
            'customer_id': customer_id,
            'transaction_date': transaction_date,
            'transaction_amount': transaction_amount
        })

df = pd.DataFrame(data)

print("=== 原始交易数据 ===")
print(df.head())
print(f"\n总交易记录数: {len(df)}")
print(f"总客户数: {df['customer_id'].nunique()}")

# 计算RFM指标
print("\n=== 计算RFM指标 ===")

# 设定分析日期
analysis_date = pd.Timestamp('2024-02-01')

# 按客户分组计算RFM
rfm = df.groupby('customer_id').agg({
    'transaction_date': lambda x: (analysis_date - x.max()).days,  # Recency
    'transaction_id': 'count',  # Frequency
    'transaction_amount': 'sum'  # Monetary
}).reset_index()

rfm.columns = ['customer_id', 'Recency', 'Frequency', 'Monetary']

print("RFM指标:")
print(rfm.head())
print("\nRFM统计摘要:")
print(rfm.describe())

# RFM指标打分（5分制）
print("\n=== RFM指标打分 ===")
rfm['R_score'] = pd.qcut(rfm['Recency'], 5, labels=[5, 4, 3, 2, 1])  # 最近购买越近分数越高
rfm['F_score'] = pd.qcut(rfm['Frequency'], 5, labels=[1, 2, 3, 4, 5])  # 购买频率越高分数越高
rfm['M_score'] = pd.qcut(rfm['Monetary'], 5, labels=[1, 2, 3, 4, 5])  # 消费金额越高分数越高

# 转换为整数
rfm['R_score'] = rfm['R_score'].astype(int)
rfm['F_score'] = rfm['F_score'].astype(int)
rfm['M_score'] = rfm['M_score'].astype(int)

# 计算总得分
rfm['Total_score'] = rfm['R_score'] + rfm['F_score'] + rfm['M_score']

print("RFM打分结果:")
print(rfm.head())

# 客户分群
print("\n=== 客户分群 ===")
# 基于RFM分数的客户分群规则
rfm['Customer_Segment'] = '一般客户'

# 重要价值客户：R高、F高、M高
rfm.loc[(rfm['R_score'] >= 4) & (rfm['F_score'] >= 4) & (rfm['M_score'] >= 4), 'Customer_Segment'] = '重要价值客户'

# 重要发展客户：R高、F低、M高
rfm.loc[(rfm['R_score'] >= 4) & (rfm['F_score'] <= 2) & (rfm['M_score'] >= 4), 'Customer_Segment'] = '重要发展客户'

# 重要保持客户：R低、F高、M高
rfm.loc[(rfm['R_score'] <= 2) & (rfm['F_score'] >= 4) & (rfm['M_score'] >= 4), 'Customer_Segment'] = '重要保持客户'

# 重要挽留客户：R低、F高、M高
rfm.loc[(rfm['R_score'] <= 2) & (rfm['F_score'] >= 3) & (rfm['M_score'] >= 3), 'Customer_Segment'] = '重要挽留客户'

# 潜力客户：R高、F中、M中
rfm.loc[(rfm['R_score'] >= 4) & (rfm['F_score'] >= 3) & (rfm['M_score'] >= 3), 'Customer_Segment'] = '潜力客户'

# 新客户：R高、F低、M低
rfm.loc[(rfm['R_score'] >= 4) & (rfm['F_score'] <= 2) & (rfm['M_score'] <= 2), 'Customer_Segment'] = '新客户'

# 流失客户：R低、F低、M低
rfm.loc[(rfm['R_score'] <= 2) & (rfm['F_score'] <= 2) & (rfm['M_score'] <= 2), 'Customer_Segment'] = '流失客户'

# 一般客户：其他

print("客户分群结果:")
segment_counts = rfm['Customer_Segment'].value_counts()
print(segment_counts)

# 使用K-Means聚类
print("\n=== K-Means聚类分析 ===")
# 标准化数据
scaler = StandardScaler()
rfm_scaled = scaler.fit_transform(rfm[['Recency', 'Frequency', 'Monetary']])

# 使用肘部法则确定最佳聚类数
inertia = []
for k in range(1, 11):
    kmeans = KMeans(n_clusters=k, random_state=42)
    kmeans.fit(rfm_scaled)
    inertia.append(kmeans.inertia_)

# 选择k=4
kmeans = KMeans(n_clusters=4, random_state=42)
rfm['KMeans_Cluster'] = kmeans.fit_predict(rfm_scaled)

print("K-Means聚类结果:")
print(rfm['KMeans_Cluster'].value_counts())

# 客户分群统计
print("\n=== 客户分群统计 ===")
segment_stats = rfm.groupby('Customer_Segment').agg({
    'Recency': 'mean',
    'Frequency': 'mean',
    'Monetary': 'mean',
    'customer_id': 'count'
}).rename(columns={'customer_id': 'Count'})

print(segment_stats)

print("\n=== 营销策略建议 ===")
print("1. 重要价值客户：提供VIP服务，专属优惠，定期维护")
print("2. 重要发展客户：增加互动，推荐相关产品，提升购买频率")
print("3. 重要保持客户：防止流失，推出回头客优惠，个性化营销")
print("4. 重要挽留客户：主动联系，挽回计划，特别优惠")
print("5. 潜力客户：培养忠诚度，交叉销售，提升客单价")
print("6. 新客户：欢迎礼包，首次购买优惠，建立联系")
print("7. 流失客户：重新激活，特别优惠，调查原因")
print("8. 一般客户：常规营销，提升参与度，寻找提升机会")
