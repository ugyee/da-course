  {
    id: 8,
    title: "财务报表自动化分析",
    description: "学习财务报表的自动分析方法，计算主要财务指标并生成分析报告",
    dataset: {
      filename: "financial_statements.csv",
      fields: [
        { name: "year", meaning: "年份", type: "int" },
