    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime
from statsmodels.tsa.holtwinters import ExponentialSmoothing

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟供应链库存数据
np.random.seed(42)
products = ['AI写作助手', '代码生成器', '图像生成API', '语音合成', '数据分析平台']
categories = ['AIGC', '开发工具', 'AIGC', 'AIGC', 'SaaS']
lead_times = [7, 14, 5, 10, 15]
unit_prices = [99, 199, 49, 79, 299]
holding_cost_rates = [0.05, 0.04, 0.06, 0.055, 0.035]

data = []
for product_idx, (product, category, lead_time, unit_price, holding_cost_rate) in enumerate(zip(products, categories, lead_times, unit_prices, holding_cost_rates)):
    # 生成6个月的日期
    dates = pd.date_range(start='2024-01-01', end='2024-06-30', freq='D')
    
    for date in dates:
        # 模拟销量
        day_of_week = date.dayofweek
        sales = np.random.randint(10, 50) + (5 if day_of_week in [5, 6] else 0)
        
        # 模拟库存水平
        inventory_level = np.random.randint(50, 300)
        
        data.append({
            'product_id': f'P{product_idx+1:03d}',
            'product_name': product,
            'category': category,
            'date': date,
            'inventory_level': inventory_level,
            'sales': sales,
            'lead_time': lead_time,
            'unit_price': unit_price,
            'holding_cost_rate': holding_cost_rate
        })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总记录数: {len(df)}")
print(f"产品数: {df['product_id'].nunique()}")

# 1. 数据探索
print("\\n=== 1. 数据探索 ===")
# 各产品总销量和平均库存
product_summary = df.groupby('product_name').agg({
    'sales': 'sum',
    'inventory_level': 'mean'
}).rename(columns={
    'sales': '总销量',
    'inventory_level': '平均库存'
})
print("产品汇总:")
print(product_summary)

# 2. 需求预测
print("\\n=== 2. 需求预测 ===")
forecast_results = []

for product in products:
    product_data = df[df['product_name'] == product].set_index('date').sort_index()
    
    # 使用霍尔特-温特斯指数平滑进行预测
    try:
        model = ExponentialSmoothing(product_data['sales'], 
                                      trend='add', 
                                      seasonal='add', 
                                      seasonal_periods=7)
        model_fit = model.fit()
        forecast = model_fit.forecast(30)  # 预测未来30天
        
        forecast_results.append({
            '产品': product,
            '平均日销量': product_data['sales'].mean(),
            '预测30天销量': forecast.sum()
        })
    except:
        print(f"{product}预测失败")

forecast_df = pd.DataFrame(forecast_results)
print("需求预测结果:")
print(forecast_df)

# 3. 库存分析
print("\\n=== 3. 库存分析 ===")
# 计算库存周转率
inventory_turnover = df.groupby('product_name').agg({
    'sales': 'sum',
    'inventory_level': 'mean'
}).assign(库存周转率=lambda x: x['sales'] / x['inventory_level'])[['库存周转率']]
print("库存周转率:")
print(inventory_turnover)

# 计算安全库存
print("\\n安全库存计算:")
for product in products:
    product_data = df[df['product_name'] == product]
    
    # 平均日销量
    avg_sales = product_data['sales'].mean()
    
    # 销量标准差
    sales_std = product_data['sales'].std()
    
    # 服务水平95%对应的Z值
    z_value = 1.65
    
    # 提前期
    lead_time = product_data['lead_time'].iloc[0]
    
    # 安全库存
    safety_stock = z_value * sales_std * np.sqrt(lead_time)
    
    # 再订货点
    reorder_point = avg_sales * lead_time + safety_stock
    
    print(f"{product}:")
    print(f"  平均日销量: {avg_sales:.2f}")
    print(f"  销量标准差: {sales_std:.2f}")
    print(f"  提前期: {lead_time}天")
    print(f"  安全库存: {safety_stock:.2f}")
    print(f"  再订货点: {reorder_point:.2f}")

# 4. 成本分析
print("\\n=== 4. 成本分析 ===")
cost_results = []
for product in products:
    product_data = df[df['product_name'] == product]
    
    unit_price = product_data['unit_price'].iloc[0]
    holding_cost_rate = product_data['holding_cost_rate'].iloc[0]
    
    # 计算平均库存
    avg_inventory = product_data['inventory_level'].mean()
    
    # 持有成本
    holding_cost = avg_inventory * unit_price * holding_cost_rate
    
    # 缺货成本（简化版，假设每次缺货损失10%销售额）
    # 这里我们简化处理，计算平均库存水平
    total_sales = product_data['sales'].sum()
    avg_sales = total_sales / len(product_data)
    stockout_cost = (max(0, avg_sales - avg_inventory) * unit_price * 0.1 * len(product_data))
    
    # 总成本
    total_cost = holding_cost + stockout_cost
    
    cost_results.append({
        '产品': product,
        '平均库存': avg_inventory,
        '持有成本': holding_cost,
        '缺货成本': stockout_cost,
        '总成本': total_cost
    })

cost_df = pd.DataFrame(cost_results).sort_values('总成本', ascending=False)
print("成本分析:")
print(cost_df)

# 5. 优化建议
print("\\n=== 5. 优化建议 ===")
print("1. 对于库存周转率低的产品，考虑减少安全库存")
print("2. 对于需求波动大的产品，适当提高安全库存")
print("3. 与供应商合作，缩短提前期，降低安全库存水平")
print("4. 优化库存管理，降低持有成本和缺货成本")
print("5. 使用ABC分类法，对不同价值产品采用不同的库存策略")
