    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report, confusion_matrix
from sklearn.preprocessing import StandardScaler, LabelEncoder

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟员工绩效数据
np.random.seed(42)
n_employees = 500

departments = ['技术部', '市场部', '销售部', '财务部', '人力资源部']
roles = ['初级数据分析师', '数据分析师', '高级数据分析师', '数据科学家', 
         '市场分析师', '销售代表', '财务分析师', 'HR专员']
education_levels = ['专科', '本科', '硕士', '博士']

data = []
for i in range(n_employees):
    department = np.random.choice(departments, p=[0.35, 0.2, 0.25, 0.1, 0.1])
    
    # 根据部门分配职位
    if department == '技术部':
        role = np.random.choice(roles[:4], p=[0.3, 0.4, 0.2, 0.1])
    elif department == '市场部':
        role = np.random.choice(roles[4:5], p=[1.0])
    elif department == '销售部':
        role = np.random.choice(roles[5:6], p=[1.0])
    elif department == '财务部':
        role = np.random.choice(roles[6:7], p=[1.0])
    else:
        role = np.random.choice(roles[7:8], p=[1.0])
    
    # 基础薪资
    base_salary = {
        '初级数据分析师': 10000,
        '数据分析师': 15000,
        '高级数据分析师': 22000,
        '数据科学家': 30000,
        '市场分析师': 12000,
        '销售代表': 9000,
        '财务分析师': 14000,
        'HR专员': 11000
    }[role]
    
    age = np.random.randint(22, 55)
    tenure = np.random.randint(1, 15)
    
    # 教育背景
    education = np.random.choice(education_levels, p=[0.2, 0.5, 0.25, 0.05])
    
    # 薪资调整
    salary = base_salary + tenure * 500 + (education_levels.index(education) - 1) * 2000
    salary = salary + np.random.normal(0, 1000)
    salary = max(8000, salary)
    
    # 绩效评分（1-5）
    performance_rating = np.random.randint(1, 6)
    
    # 完成项目数
    projects_completed = 5 + tenure * 2 + performance_rating * 2 + np.random.randint(0, 5)
    
    # 平均项目评分
    average_project_score = 2.5 + performance_rating * 0.5 + np.random.normal(0, 0.3)
    average_project_score = max(1.0, min(5.0, average_project_score))
    
    # 加班时长
    overtime_hours = np.random.randint(20, 200)
    
    # 培训时长
    training_hours = np.random.randint(10, 100)
    
    data.append({
        'employee_id': f'E{i+1:03d}',
        'department': department,
        'role': role,
        'age': age,
        'tenure': tenure,
        'education': education,
        'salary': salary,
        'performance_rating': performance_rating,
        'projects_completed': projects_completed,
        'average_project_score': average_project_score,
        'overtime_hours': overtime_hours,
        'training_hours': training_hours
    })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总员工数: {len(df)}")

# 1. 数据探索
print("\\n=== 1. 数据探索 ===")
# 描述性统计
print(df.describe())

# 各部门人数
department_counts = df['department'].value_counts()
print("\\n各部门人数:")
print(department_counts)

# 绩效分布
print("\\n绩效分布:")
print(df['performance_rating'].value_counts().sort_index())

# 2. 部门绩效分析
print("\\n=== 2. 部门绩效分析 ===")
department_performance = df.groupby('department').agg({
    'performance_rating': 'mean',
    'salary': 'mean',
    'projects_completed': 'mean',
    'average_project_score': 'mean'
}).round(2).sort_values('performance_rating', ascending=False)
print("部门绩效:")
print(department_performance)

# 3. 高绩效员工特征分析
print("\\n=== 3. 高绩效员工特征分析 ===")
high_performers = df[df['performance_rating'] >= 4]
low_performers = df[df['performance_rating'] <= 2]

# 对比分析
comparison_features = ['age', 'tenure', 'salary', 'projects_completed', 'average_project_score', 'overtime_hours', 'training_hours']
high_perf_stats = high_performers[comparison_features].mean().round(2)
low_perf_stats = low_performers[comparison_features].mean().round(2)
comparison_df = pd.DataFrame({'高绩效员工': high_perf_stats, '低绩效员工': low_perf_stats})
comparison_df['差异'] = ((comparison_df['高绩效员工'] - comparison_df['低绩效员工']) / comparison_df['低绩效员工'] * 100).round(2)
print("高绩效与低绩效员工对比:")
print(comparison_df)

# 4. 绩效预测
print("\\n=== 4. 绩效预测 ===")
# 准备数据
X = df[['age', 'tenure', 'salary', 'projects_completed', 'average_project_score', 'overtime_hours', 'training_hours']].copy()

# 编码分类变量
le_department = LabelEncoder()
le_role = LabelEncoder()
le_education = LabelEncoder()

X['department'] = le_department.fit_transform(df['department'])
X['role'] = le_role.fit_transform(df['role'])
X['education'] = le_education.fit_transform(df['education'])

y = df['performance_rating']

# 划分训练集和测试集
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)

# 特征标准化
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# 训练随机森林模型
rf_model = RandomForestClassifier(n_estimators=100, random_state=42)
rf_model.fit(X_train_scaled, y_train)

# 预测
y_pred = rf_model.predict(X_test_scaled)

# 评估
print("模型评估:")
print(classification_report(y_test, y_pred))

# 特征重要性
print("\\n特征重要性:")
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': rf_model.feature_importances_
}).sort_values('importance', ascending=False)
print(feature_importance)

# 5. 绩效提升建议
print("\\n=== 5. 绩效提升建议 ===")
print("1. 培训时长与绩效呈正相关，建议增加员工培训机会")
print("2. 高绩效员工完成的项目更多，平均项目评分更高")
print("3. 司龄与绩效有一定关系，但不是线性关系")
print("4. 建议为低绩效员工制定个性化改进计划")
print("5. 建立有效的激励机制，提升员工工作积极性")
`,
    expectedResults: [
      "数据探索结果",
      "部门绩效分析结果",
      "高绩效员工特征分析结果",
      "绩效预测结果",
      "绩效提升建议"
    ],
    advancedTasks: [
      "实现更复杂的绩效预测模型",
      "分析团队绩效",
      "设计绩效管理系统",
      "制定个性化绩效改进方案"
    ]
  }
];
