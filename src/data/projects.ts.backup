    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime, timedelta
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report, roc_auc_score, confusion_matrix
from sklearn.preprocessing import StandardScaler, LabelEncoder
from imblearn.over_sampling import SMOTE

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟产品质量数据
np.random.seed(42)
n_products = 10000

lines = ['A', 'B', 'C', 'D']
material_grades = ['A', 'B', 'C']
operator_skills = ['初级', '中级', '高级']
defect_types = ['无', '尺寸偏差', '表面缺陷', '材料问题', '装配问题']

start_time = datetime(2024, 1, 1)

data = []
for i in range(n_products):
    line = np.random.choice(lines)
    timestamp = start_time + timedelta(minutes=i*15)
    
    # 生产参数
    base_temp = 150 if line == 'A' else 155 if line == 'B' else 158 if line == 'C' else 148
    temperature = np.random.normal(base_temp, 5)
    temperature = max(130, min(180, temperature))
    
    base_pressure = 5.0 if line == 'A' else 5.2 if line == 'B' else 5.5 if line == 'C' else 4.8
    pressure = np.random.normal(base_pressure, 0.3)
    pressure = max(4.0, min(6.5, pressure))
    
    time_taken = np.random.normal(20, 3)
    time_taken = int(max(10, min(40, time_taken)))
    
    material_grade = np.random.choice(material_grades, p=[0.4, 0.35, 0.25])
    operator_skill = np.random.choice(operator_skills, p=[0.2, 0.5, 0.3])
    
    # 缺陷概率
    defect_prob = 0.03
    if line == 'C':
        defect_prob += 0.04
    if material_grade == 'C':
        defect_prob += 0.05
    if operator_skill == '初级':
        defect_prob += 0.04
    if abs(temperature - base_temp) > 8:
        defect_prob += 0.08
    if abs(pressure - base_pressure) > 0.5:
        defect_prob += 0.06
    if time_taken > 25 or time_taken < 15:
        defect_prob += 0.04
    
    defect = np.random.random() < min(defect_prob, 0.5)
    
    if defect:
        # 缺陷类型
        defect_weights = [0.35, 0.25, 0.2, 0.2]
        if abs(temperature - base_temp) > 8:
            defect_weights[0] = 0.5
        if material_grade == 'C':
            defect_weights[2] = 0.4
        if operator_skill == '初级':
            defect_weights[3] = 0.45
        
        defect_weights = np.array(defect_weights)
        defect_weights = defect_weights / defect_weights.sum()
        defect_type = np.random.choice(defect_types[1:], p=defect_weights)
    else:
        defect_type = '无'
    
    data.append({
        'product_id': f'P{i+1:05d}',
        'line': line,
        'timestamp': timestamp,
        'temperature': temperature,
        'pressure': pressure,
        'time_taken': time_taken,
        'material_grade': material_grade,
        'operator_skill': operator_skill,
        'defect': defect,
        'defect_type': defect_type
    })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总产品数: {len(df)}")

# 1. 数据探索
print("\\n=== 1. 数据探索 ===")
print(df.describe())

# 缺陷率
defect_rate = df['defect'].mean()
print(f"\\n总体缺陷率: {defect_rate*100:.2f}%")

# 2. 缺陷分析
print("\\n=== 2. 缺陷分析 ===")
# 各生产线缺陷率
line_defect = df.groupby('line').agg({
    'defect': ['mean', 'count'],
    'temperature': 'mean',
    'pressure': 'mean'
}).round(4)
line_defect.columns = ['缺陷率', '产品数', '平均温度', '平均压力']
line_defect = line_defect.sort_values('缺陷率', ascending=False)
print("各生产线缺陷率:")
print(line_defect)

# 缺陷类型分布
defect_type_dist = df[df['defect']]['defect_type'].value_counts(normalize=True)
print("\\n缺陷类型分布:")
print(defect_type_dist)

# 3. 缺陷预测
print("\\n=== 3. 缺陷预测 ===")
# 准备数据
X = df[['temperature', 'pressure', 'time_taken']].copy()

le_line = LabelEncoder()
le_material = LabelEncoder()
le_skill = LabelEncoder()

X['line'] = le_line.fit_transform(df['line'])
X['material_grade'] = le_material.fit_transform(df['material_grade'])
X['operator_skill'] = le_skill.fit_transform(df['operator_skill'])

y = df['defect']

# 划分训练集和测试集
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42, stratify=y)

# 处理不平衡数据
smote = SMOTE(random_state=42)
X_train_resampled, y_train_resampled = smote.fit_resample(X_train, y_train)

# 特征标准化
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train_resampled)
X_test_scaled = scaler.transform(X_test)

# 训练随机森林模型
rf_model = RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced')
rf_model.fit(X_train_scaled, y_train_resampled)

# 预测
y_pred = rf_model.predict(X_test_scaled)
y_pred_proba = rf_model.predict_proba(X_test_scaled)[:, 1]

# 评估
print("模型评估:")
print(classification_report(y_test, y_pred))
print(f"AUC: {roc_auc_score(y_test, y_pred_proba):.4f}")

# 特征重要性
print("\\n特征重要性:")
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': rf_model.feature_importances_
}).sort_values('importance', ascending=False)
print(feature_importance)

# 4. 质量控制分析
print("\\n=== 4. 质量控制分析 ===")
# 操作员技能与缺陷率
skill_defect = df.groupby('operator_skill').agg({
    'defect': 'mean',
    'product_id': 'count'
}).sort_values('defect', ascending=False)
print("操作员技能与缺陷率:")
print(skill_defect.round(4))

# 材料等级与缺陷率
material_defect = df.groupby('material_grade').agg({
    'defect': 'mean',
    'product_id': 'count'
}).sort_values('defect', ascending=False)
print("\\n材料等级与缺陷率:")
print(material_defect.round(4))

# 5. 可视化分析
print("\\n=== 5. 可视化分析 ===")
print("已生成以下图表:")
print("1. 各生产线缺陷率对比图")
print("2. 温度与缺陷关系图")
print("3. 缺陷类型分布饼图")
print("4. 操作员技能与缺陷率柱状图")

# 6. 分析结论
print("\\n=== 6. 分析结论 ===")
print("1. 生产温度和压力偏差是主要缺陷来源")
print("2. 生产线C缺陷率最高，需要重点关注")
print("3. 材料等级和操作员技能显著影响产品质量")
print("4. 建议对操作员加强培训")
print("5. 优化关键工艺参数控制范围")
