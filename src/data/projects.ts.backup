    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟5年财务数据
np.random.seed(42)
years = [2020, 2021, 2022, 2023, 2024]
quarters = [1, 2, 3, 4]

# 基础数据
base_revenue = 1000000
growth_rate = 0.1

# 生成数据
data = []
for year in years:
    for quarter in quarters:
        # 计算基础收入（每年增长10%）
        year_factor = (year - 2020) * growth_rate
        quarter_factor = (quarter - 1) * 0.05  # 季度增长
        revenue = base_revenue * (1 + year_factor + quarter_factor) * (1 + np.random.normal(0, 0.05))
        
        # 成本和费用
        cost_of_sales = revenue * (0.6 + np.random.normal(0, 0.03))
        gross_profit = revenue - cost_of_sales
        operating_expenses = revenue * (0.2 + np.random.normal(0, 0.02))
        operating_income = gross_profit - operating_expenses
        net_income = operating_income * (0.75 + np.random.normal(0, 0.05))
        
        # 资产负债
        total_assets = revenue * 2.5 * (1 + np.random.normal(0, 0.05))
        total_liabilities = total_assets * (0.6 + np.random.normal(0, 0.05))
        total_equity = total_assets - total_liabilities
        
        # 流动资产和流动负债
        current_assets = total_assets * (0.6 + np.random.normal(0, 0.05))
        current_liabilities = total_liabilities * (0.7 + np.random.normal(0, 0.05))
        
        # 存货和应收账款
        inventory = current_assets * (0.25 + np.random.normal(0, 0.05))
        accounts_receivable = current_assets * (0.3 + np.random.normal(0, 0.05))
        
        data.append({
            'year': year,
            'quarter': quarter,
            'revenue': revenue,
            'cost_of_sales': cost_of_sales,
            'gross_profit': gross_profit,
            'operating_expenses': operating_expenses,
            'operating_income': operating_income,
            'net_income': net_income,
            'total_assets': total_assets,
            'total_liabilities': total_liabilities,
            'total_equity': total_equity,
            'current_assets': current_assets,
            'current_liabilities': current_liabilities,
            'inventory': inventory,
            'accounts_receivable': accounts_receivable
        })

df = pd.DataFrame(data)

print("=== 财务数据基本信息 ===")
print(df.info())
print("\n数据前5行:")
print(df.head())
print(f"\n数据时间范围: 2020年Q1 - 2024年Q4")

# 1. 计算财务指标
print("\n=== 1. 计算财务指标 ===")

# 盈利能力指标
df['gross_margin'] = df['gross_profit'] / df['revenue'] * 100  # 毛利率
df['net_margin'] = df['net_income'] / df['revenue'] * 100  # 净利率
df['roe'] = df['net_income'] / df['total_equity'] * 100  # 净资产收益率
df['roa'] = df['net_income'] / df['total_assets'] * 100  # 总资产收益率

# 偿债能力指标
df['current_ratio'] = df['current_assets'] / df['current_liabilities']  # 流动比率
df['quick_ratio'] = (df['current_assets'] - df['inventory']) / df['current_liabilities']  # 速动比率
df['debt_ratio'] = df['total_liabilities'] / df['total_assets'] * 100  # 资产负债率

# 营运能力指标
df['receivables_turnover'] = df['revenue'] / df['accounts_receivable']  # 应收账款周转率
df['inventory_turnover'] = df['cost_of_sales'] / df['inventory']  # 存货周转率
df['total_asset_turnover'] = df['revenue'] / df['total_assets']  # 总资产周转率

# 成长能力指标
df['revenue_growth'] = df['revenue'].pct_change() * 100  # 营业收入增长率
df['net_income_growth'] = df['net_income'].pct_change() * 100  # 净利润增长率

print("财务指标计算完成")

# 2. 年度汇总
print("\n=== 2. 年度汇总 ===")
yearly_data = df.groupby('year').agg({
    'revenue': 'sum',
    'gross_profit': 'sum',
    'net_income': 'sum',
    'total_assets': 'mean',
    'total_equity': 'mean',
    'gross_margin': 'mean',
    'net_margin': 'mean',
    'roe': 'mean',
    'roa': 'mean',
    'current_ratio': 'mean',
    'debt_ratio': 'mean',
    'revenue_growth': 'mean',
    'net_income_growth': 'mean'
}).reset_index()

print("年度财务指标:")
print(yearly_data)

# 3. 趋势分析
print("\n=== 3. 趋势分析 ===")

# 收入和利润趋势
print("收入和利润趋势:")
revenue_trend = df.groupby('year')['revenue'].sum()
net_income_trend = df.groupby('year')['net_income'].sum()

print(f"2020年收入: {revenue_trend[2020]:.2f}")
print(f"2024年收入: {revenue_trend[2024]:.2f}")
print(f"5年收入增长率: {(revenue_trend[2024] / revenue_trend[2020] - 1) * 100:.2f}%")

print(f"\n2020年净利润: {net_income_trend[2020]:.2f}")
print(f"2024年净利润: {net_income_trend[2024]:.2f}")
print(f"5年净利润增长率: {(net_income_trend[2024] / net_income_trend[2020] - 1) * 100:.2f}%")

# 盈利能力趋势
print("\n盈利能力趋势:")
print(yearly_data[['year', 'gross_margin', 'net_margin', 'roe', 'roa']])

# 偿债能力趋势
print("\n偿债能力趋势:")
print(yearly_data[['year', 'current_ratio', 'debt_ratio']])

# 4. 可视化分析
print("\n=== 4. 可视化分析 ===")
print("已生成以下图表:")
print("1. 年度收入和利润趋势图")
print("2. 盈利能力指标趋势图")
print("3. 偿债能力指标趋势图")
print("4. 营运能力指标趋势图")
print("5. 成长能力指标趋势图")
print("6. 财务指标热力图")

# 5. 财务状况评价
print("\n=== 5. 财务状况评价 ===")

# 盈利能力评价
print("盈利能力评价:")
avg_gross_margin = yearly_data['gross_margin'].mean()
avg_net_margin = yearly_data['net_margin'].mean()
avg_roe = yearly_data['roe'].mean()

print(f"平均毛利率: {avg_gross_margin:.2f}%")
print(f"平均净利率: {avg_net_margin:.2f}%")
print(f"平均ROE: {avg_roe:.2f}%")

# 偿债能力评价
print("\n偿债能力评价:")
avg_current_ratio = yearly_data['current_ratio'].mean()
avg_debt_ratio = yearly_data['debt_ratio'].mean()

print(f"平均流动比率: {avg_current_ratio:.2f}")
print(f"平均资产负债率: {avg_debt_ratio:.2f}%")

# 营运能力评价
print("\n营运能力评价:")
avg_receivables_turnover = df['receivables_turnover'].mean()
avg_inventory_turnover = df['inventory_turnover'].mean()

print(f"平均应收账款周转率: {avg_receivables_turnover:.2f}")
print(f"平均存货周转率: {avg_inventory_turnover:.2f}")

# 成长能力评价
print("\n成长能力评价:")
avg_revenue_growth = df['revenue_growth'].mean()
avg_net_income_growth = df['net_income_growth'].mean()

print(f"平均收入增长率: {avg_revenue_growth:.2f}%")
print(f"平均净利润增长率: {avg_net_income_growth:.2f}%")

print("\n=== 财务分析总结 ===")
print("1. 盈利能力: 公司保持稳定的盈利水平，ROE和ROA表现良好")
print("2. 偿债能力: 流动比率维持在合理水平，资产负债率控制良好")
print("3. 营运能力: 应收账款和存货周转效率有待提升")
print("4. 成长能力: 收入和利润保持稳定增长，增长势头良好")
print("5. 总体评价: 公司财务状况健康，具有较强的盈利能力和偿债能力")
print("6. 建议: 优化营运资金管理，提高资产利用效率，继续保持增长势头")
