    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟电商用户行为数据
np.random.seed(42)
n_records = 10000

user_ids = [f'U{i:03d}' for i in range(1, 501)]
session_ids = [f'S{i:05d}' for i in range(1, n_records + 1)]
event_types = ['浏览', '加购', '收藏', '购买']
product_ids = [f'P{i:03d}' for i in range(1, 101)]
channels = ['社交媒体', '搜索引擎', '直接访问', '广告']
devices = ['移动端', 'PC端', '平板']

# 生成时间戳
start_date = datetime(2024, 1, 1)
timestamps = [start_date + pd.Timedelta(days=np.random.randint(0, 30), 
                                          hours=np.random.randint(0, 24),
                                          minutes=np.random.randint(0, 60))
                for _ in range(n_records)]

# 生成数据
data = []
for i in range(n_records):
    event_type = np.random.choice(event_types, p=[0.6, 0.2, 0.15, 0.05])
    revenue = 0.0
    if event_type == '购买':
        revenue = np.random.randint(50, 500)
    
    data.append({
        'user_id': np.random.choice(user_ids),
        'session_id': session_ids[i],
        'event_type': event_type,
        'product_id': np.random.choice(product_ids),
        'timestamp': timestamps[i],
        'channel': np.random.choice(channels, p=[0.3, 0.4, 0.2, 0.1]),
        'device': np.random.choice(devices, p=[0.6, 0.35, 0.05]),
        'revenue': revenue
    })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总记录数: {len(df)}")
print(f"独立用户数: {df['user_id'].nunique()}")

# 1. 数据预处理
print("\\n=== 1. 数据预处理 ===")
# 转换时间戳格式
df['timestamp'] = pd.to_datetime(df['timestamp'])
df['date'] = df['timestamp'].dt.date
df['hour'] = df['timestamp'].dt.hour
df['day_of_week'] = df['timestamp'].dt.dayofweek

# 2. 用户行为分析
print("\\n=== 2. 用户行为分析 ===")
# 各事件类型分布
event_distribution = df['event_type'].value_counts(normalize=True)
print("事件类型分布:")
print(event_distribution)

# 转化率
conversion_rate = len(df[df['event_type'] == '购买']) / len(df)
print(f"\\n总体转化率: {conversion_rate*100:.2f}%")

# 3. 渠道分析
print("\\n=== 3. 渠道分析 ===")
channel_performance = df.groupby('channel').agg({
    'user_id': 'nunique',
    'revenue': 'sum',
    'event_type': lambda x: len(x[x == '购买']) / len(x)
}).rename(columns={
    'user_id': '用户数',
    'revenue': '总收入',
    'event_type': '转化率'
}).sort_values('总收入', ascending=False)
print("渠道表现:")
print(channel_performance)

# 4. 设备分析
print("\\n=== 4. 设备分析 ===")
device_performance = df.groupby('device').agg({
    'user_id': 'nunique',
    'revenue': 'sum',
    'event_type': lambda x: len(x[x == '购买']) / len(x)
}).rename(columns={
    'user_id': '用户数',
    'revenue': '总收入',
    'event_type': '转化率'
}).sort_values('总收入', ascending=False)
print("设备表现:")
print(device_performance)

# 5. 用户分群
print("\\n=== 5. 用户分群 ===")
user_metrics = df.groupby('user_id').agg({
    'event_type': 'count',  # 总行为数
    'revenue': 'sum',  # 总收入
    'timestamp': lambda x: (x.max() - x.min()).days + 1  # 活跃天数
}).rename(columns={
    'event_type': '总行为数',
    'revenue': '总收入',
    'timestamp': '活跃天数'
}).fillna(0)

# 购买用户
purchase_users = df[df['event_type'] == '购买']['user_id'].unique()
user_metrics['是否购买'] = user_metrics.index.isin(purchase_users)

# 基于总行为数和总收入分群
user_metrics['用户价值'] = '低价值用户'
user_metrics.loc[(user_metrics['总行为数'] >= 10) & (user_metrics['总收入'] < 100), '用户价值'] = '中价值用户'
user_metrics.loc[(user_metrics['总行为数'] >= 10) & (user_metrics['总收入'] >= 100), '用户价值'] = '高价值用户'
user_metrics.loc[user_metrics['总收入'] >= 1000, '用户价值'] = '超高价值用户'

print("用户分群:")
print(user_metrics['用户价值'].value_counts())

# 6. 可视化分析
print("\\n=== 6. 可视化分析 ===")
print("已生成以下图表:")
print("1. 事件类型分布饼图")
print("2. 各渠道收入对比柱状图")
print("3. 用户价值分布饼图")
print("4. 小时级行为分布热力图")

# 7. 分析结论
print("\\n=== 7. 分析结论 ===")
print("1. 浏览是最常见的行为，购买转化率较低")
print("2. 搜索引擎带来的用户最多，社交媒体带来的收入最高")
print("3. 移动端用户量最大，但PC端转化率更高")
print("4. 建议针对高价值用户进行精准营销")
print("5. 优化移动端购买流程，提高转化率")
