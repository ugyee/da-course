    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.linear_model import LogisticRegression
from sklearn.tree import DecisionTreeClassifier
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, roc_curve, auc
from sklearn.model_selection import GridSearchCV

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟客户流失数据
np.random.seed(42)
n_customers = 1000

# 基本信息
genders = np.random.choice(['男', '女'], n_customers)
ages = np.random.randint(18, 70, n_customers)
tenures = np.random.randint(1, 72, n_customers)
monthly_charges = np.random.uniform(30, 150, n_customers)
total_charges = monthly_charges * tenures

# 服务信息
contract_types = np.random.choice(['月付', '季付', '年付'], n_customers, p=[0.6, 0.2, 0.2])
payment_methods = np.random.choice(['信用卡', '银行转账', '电子钱包'], n_customers)
internet_services = np.random.choice(['ADSL', '光纤', '无'], n_customers, p=[0.4, 0.5, 0.1])

# 生成流失标签（基于 tenure 和 contract_type）
churn_prob = np.zeros(n_customers)
# 月付用户流失概率更高
churn_prob[contract_types == '月付'] = 0.3
churn_prob[contract_types == '季付'] = 0.15
churn_prob[contract_types == '年付'] = 0.05
# 短期用户流失概率更高
churn_prob[tenures < 6] *= 2
churn_prob = np.clip(churn_prob, 0, 1)

churn = np.random.binomial(1, churn_prob, n_customers).astype(bool)

# 创建数据集
df = pd.DataFrame({
    'customer_id': [f'C{i:03d}' for i in range(1, n_customers + 1)],
    'gender': genders,
    'age': ages,
    'tenure': tenures,
    'monthly_charges': monthly_charges,
    'total_charges': total_charges,
    'contract_type': contract_types,
    'payment_method': payment_methods,
    'internet_service': internet_services,
    'churn': churn
})

print("=== 数据基本信息 ===")
print(df.info())
print("\n数据前5行:")
print(df.head())
print(f"\n总客户数: {len(df)}")
print(f"流失客户数: {df['churn'].sum()}")
print(f"流失率: {df['churn'].mean()*100:.2f}%")

# 1. 数据探索与可视化
print("\n=== 1. 数据探索与可视化 ===")

# 流失率分析
print("\n各特征的流失率:")
for col in ['gender', 'contract_type', 'payment_method', 'internet_service']:
    print(f"\n{col}:")
    print(df.groupby(col)['churn'].mean())

# 数值特征分析
print("\n数值特征统计:")
print(df[['age', 'tenure', 'monthly_charges', 'total_charges']].describe())

# 2. 特征工程
print("\n=== 2. 特征工程 ===")

# 类别变量编码
label_encoders = {}
for col in ['gender', 'contract_type', 'payment_method', 'internet_service']:
    le = LabelEncoder()
    df[col] = le.fit_transform(df[col])
    label_encoders[col] = le

# 准备特征和标签
X = df.drop(['customer_id', 'churn'], axis=1)
y = df['churn']

# 3. 数据集划分
print("\n=== 3. 数据集划分 ===")
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)
print(f"训练集大小: {len(X_train)}, 测试集大小: {len(X_test)}")

# 4. 数据标准化
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# 5. 模型训练
print("\n=== 5. 模型训练 ===")

# 逻辑回归
print("\n5.1 逻辑回归:")
lr_model = LogisticRegression(random_state=42)
lr_model.fit(X_train_scaled, y_train)
y_pred_lr = lr_model.predict(X_test_scaled)
y_pred_proba_lr = lr_model.predict_proba(X_test_scaled)[:, 1]

# 决策树
print("\n5.2 决策树:")
dt_model = DecisionTreeClassifier(random_state=42)
dt_model.fit(X_train, y_train)
y_pred_dt = dt_model.predict(X_test)
y_pred_proba_dt = dt_model.predict_proba(X_test)[:, 1]

# 随机森林
print("\n5.3 随机森林:")
rf_model = RandomForestClassifier(random_state=42)
rf_model.fit(X_train, y_train)
y_pred_rf = rf_model.predict(X_test)
y_pred_proba_rf = rf_model.predict_proba(X_test)[:, 1]

# 6. 模型评估
print("\n=== 6. 模型评估 ===")

models = {
    '逻辑回归': (y_pred_lr, y_pred_proba_lr),
    '决策树': (y_pred_dt, y_pred_proba_dt),
    '随机森林': (y_pred_rf, y_pred_proba_rf)
}

for model_name, (y_pred, y_pred_proba) in models.items():
    accuracy = accuracy_score(y_test, y_pred)
    precision = precision_score(y_test, y_pred)
    recall = recall_score(y_test, y_pred)
    f1 = f1_score(y_test, y_pred)
    fpr, tpr, _ = roc_curve(y_test, y_pred_proba)
    roc_auc = auc(fpr, tpr)
    
    print(f"\n{model_name}:")
    print(f"准确率: {accuracy:.4f}")
    print(f"精确率: {precision:.4f}")
    print(f"召回率: {recall:.4f}")
    print(f"F1值: {f1:.4f}")
    print(f"AUC值: {roc_auc:.4f}")

# 7. 模型优化
print("\n=== 7. 模型优化 ===")

# 随机森林超参数调优
param_grid = {
    'n_estimators': [50, 100, 200],
    'max_depth': [3, 5, 7, 10],
    'min_samples_split': [2, 5, 10]
}

grid_search = GridSearchCV(RandomForestClassifier(random_state=42), param_grid, cv=5, scoring='f1')
grid_search.fit(X_train, y_train)

print("最佳参数:")
print(grid_search.best_params_)
print(f"最佳F1分数: {grid_search.best_score_:.4f}")

# 使用最佳模型
best_rf_model = grid_search.best_estimator_
y_pred_best = best_rf_model.predict(X_test)
print(f"\n优化后模型F1分数: {f1_score(y_test, y_pred_best):.4f}")

# 8. 特征重要性分析
print("\n=== 8. 特征重要性分析 ===")
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': best_rf_model.feature_importances_
}).sort_values('importance', ascending=False)

print("特征重要性:")
print(feature_importance)

print("\n=== 分析总结 ===")
print("1. 客户流失率为: {:.2f}%".format(df['churn'].mean()*100))
print("2. 最重要的影响因素:")
for i, (feature, importance) in enumerate(zip(feature_importance['feature'], feature_importance['importance'])):
    print(f"   {i+1}. {feature}: {importance:.4f}")
print("3. 随机森林模型在优化后取得了最好的性能")
print("4. 建议针对高风险客户制定挽留策略，特别是月付用户和短期用户")
