        ["C002", "45", "80", "0.2", "780", "200", "20", "False", "金融"],
        ["C003", "28", "12", "0.5", "600", "30", "5", "True", "零售"],
        ["C004", "50", "150", "0.25", "800", "500", "30", "False", "医疗"],
