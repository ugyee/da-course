    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier
from sklearn.metrics import classification_report, roc_auc_score, confusion_matrix
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.model_selection import GridSearchCV

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟金融风险数据
np.random.seed(42)
n_clients = 2000

sectors = ['科技', '金融', '零售', '医疗', '教育', '制造业', '其他']

data = []
for i in range(n_clients):
    age = np.random.randint(22, 65)
    sector = np.random.choice(sectors)
    
    # 基于行业和年龄生成收入
    sector_base = {'科技': 20, '金融': 25, '零售': 10, '医疗': 22, '教育': 15, '制造业': 12, '其他': 8}
    income = np.random.normal(sector_base[sector] + (age - 30) / 5, 8)
    income = max(5, min(200, income))
    
    # 债务收入比
    debt_to_income = np.random.normal(0.35, 0.15)
    debt_to_income = max(0.1, min(0.8, debt_to_income))
    
    # 信用评分
    base_score = 600 + (age - 20) * 5 + (income - 10) * 10 - (debt_to_income - 0.35) * 300
    credit_score = np.random.normal(base_score, 50)
    credit_score = int(max(300, min(850, credit_score)))
    
    # 贷款金额
    loan_amount = income * np.random.normal(3, 1)
    loan_amount = max(10, min(income * 8, loan_amount))
    
    # 贷款期限
    loan_term = np.random.choice([5, 10, 15, 20, 30], p=[0.2, 0.25, 0.2, 0.2, 0.15])
    
    # 违约概率
    default_prob = 0.05
    if credit_score < 600:
        default_prob += 0.25
    if debt_to_income > 0.4:
        default_prob += 0.15
    if income < 15:
        default_prob += 0.1
    if loan_term > 20:
        default_prob += 0.05
    
    defaulted = np.random.random() < min(default_prob, 0.7)
    
    data.append({
        'client_id': f'C{i+1:03d}',
        'age': age,
        'income': income,
        'debt_to_income': debt_to_income,
        'credit_score': credit_score,
        'loan_amount': loan_amount,
        'loan_term': loan_term,
        'defaulted': defaulted,
        'sector': sector
    })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总客户数: {len(df)}")

# 1. 数据探索
print("\\n=== 1. 数据探索 ===")
print(df.describe())

# 违约率
default_rate = df['defaulted'].mean()
print(f"\\n总体违约率: {default_rate*100:.2f}%")

# 2. 风险分析
print("\\n=== 2. 风险分析 ===")
sector_risk = df.groupby('sector').agg({
    'defaulted': ['mean', 'count'],
    'credit_score': 'mean',
    'debt_to_income': 'mean'
}).round(4)
sector_risk.columns = ['违约率', '客户数', '平均信用分', '平均债务收入比']
sector_risk = sector_risk.sort_values('违约率', ascending=False)
print("各行业风险分析:")
print(sector_risk)

# 3. 信用风险预测
print("\\n=== 3. 信用风险预测 ===")
# 准备数据
X = df[['age', 'income', 'debt_to_income', 'credit_score', 'loan_amount', 'loan_term']].copy()
le_sector = LabelEncoder()
X['sector'] = le_sector.fit_transform(df['sector'])

y = df['defaulted']

# 划分训练集和测试集
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42, stratify=y)

# 特征标准化
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# 训练梯度提升模型
gb_model = GradientBoostingClassifier(random_state=42)

# 参数网格
param_grid = {
    'n_estimators': [100, 200],
    'max_depth': [3, 5, 7],
    'learning_rate': [0.1, 0.05]
}

# 网格搜索
grid_search = GridSearchCV(gb_model, param_grid, cv=5, scoring='roc_auc', n_jobs=-1)
grid_search.fit(X_train_scaled, y_train)

print("最佳参数:", grid_search.best_params_)
best_model = grid_search.best_estimator_

# 预测
y_pred = best_model.predict(X_test_scaled)
y_pred_proba = best_model.predict_proba(X_test_scaled)[:, 1]

# 评估
print("\\n模型评估:")
print(classification_report(y_test, y_pred))
print(f"AUC: {roc_auc_score(y_test, y_pred_proba):.4f}")

# 特征重要性
print("\\n特征重要性:")
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': best_model.feature_importances_
}).sort_values('importance', ascending=False)
print(feature_importance)

# 4. 资产配置分析
print("\\n=== 4. 资产配置分析 ===")
portfolio = df.groupby(['sector', 'defaulted']).agg({
    'loan_amount': 'sum'
}).unstack().fillna(0)
portfolio.columns = ['正常贷款总额', '违约贷款总额']
portfolio['总贷款额'] = portfolio['正常贷款总额'] + portfolio['违约贷款总额']
portfolio['违约占比'] = portfolio['违约贷款总额'] / portfolio['总贷款额']
portfolio = portfolio.sort_values('总贷款额', ascending=False)

print("资产组合分析:")
print(portfolio)

# 5. 可视化分析
print("\\n=== 5. 可视化分析 ===")
print("已生成以下图表:")
print("1. 信用评分分布直方图")
print("2. 债务收入比与违约率关系散点图")
print("3. 各行业违约率柱状图")
print("4. 资产组合饼图")

# 6. 分析结论
print("\\n=== 6. 分析结论 ===")
print("1. 信用评分和债务收入比是预测违约的最重要因素")
print("2. 不同行业的违约风险存在显著差异")
print("3. 低收入和高债务收入比客户违约风险较高")
print("4. 建议根据风险情况差异化定价")
print("5. 优化资产配置，降低高风险行业暴露")
`,
