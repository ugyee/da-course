    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime
from sklearn.linear_model import LinearRegression
from sklearn.preprocessing import StandardScaler
import warnings

warnings.filterwarnings('ignore')

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟产品价格敏感度数据
np.random.seed(42)
products = ['AI写作助手', '代码生成器', '图像生成API', '语音合成', '数据分析平台']
base_prices = [99, 199, 49, 79, 299]
base_sales = [20, 15, 50, 30, 10]
price_elasticities = [-1.5, -1.2, -2.0, -1.8, -1.0]

data = []
for product_idx, (product, base_price, base_sale, elasticity) in enumerate(zip(products, base_prices, base_sales, price_elasticities)):
    # 生成6个月的日期
    dates = pd.date_range(start='2024-01-01', end='2024-06-30', freq='D')
    
    for date in dates:
        # 随机价格波动
        price_variation = np.random.normal(0, 0.1)
        price = base_price * (1 + price_variation)
        
        # 促销概率
        promotion = np.random.random() < 0.2
        if promotion:
            price = price * 0.9  # 促销价9折
        
        # 销量模型
        price_change = (price - base_price) / base_price
        sales_change = elasticity * price_change
        
        # 促销带来的销量增长
        if promotion:
            sales_change += 0.5
        
        # 广告支出影响
        advertising_spend = np.random.randint(500, 2000)
        advertising_impact = advertising_spend / 10000
        
        # 竞争对手价格
        competitor_price = base_price * 1.1 + np.random.normal(0, 5)
        price_ratio = price / competitor_price
        competition_impact = (1 - price_ratio) * 0.3
        
        # 随机波动
        random_change = np.random.normal(0, 0.2)
        
        # 最终销量
        sales_volume = int(base_sale * (1 + sales_change + advertising_impact + competition_impact + random_change))
        sales_volume = max(1, sales_volume)
        
        data.append({
            'product_id': f'P{product_idx+1:03d}',
            'product_name': product,
            'date': date,
            'price': price,
            'sales_volume': sales_volume,
            'promotion': promotion,
            'advertising_spend': advertising_spend,
            'competitor_price': competitor_price
        })

df = pd.DataFrame(data)
print("=== 原始数据 ===")
print(df.head())
print(f"总记录数: {len(df)}")

# 1. 数据探索
print("\\n=== 1. 数据探索 ===")
# 各产品汇总
product_summary = df.groupby('product_name').agg({
    'price': ['mean', 'min', 'max'],
    'sales_volume': ['mean', 'sum'],
    'promotion': 'mean'
}).round(2)
product_summary.columns = ['平均价格', '最低价格', '最高价格', '平均销量', '总销量', '促销比例']
print("产品汇总:")
print(product_summary)

# 2. 价格与销量关系分析
print("\\n=== 2. 价格与销量关系分析 ===")
for product in products:
    product_data = df[df['product_name'] == product]
    
    # 计算价格弹性
    # 销量变化百分比 / 价格变化百分比
    product_data_sorted = product_data.sort_values('date')
    
    # 忽略促销期间的数据
    product_data_regular = product_data_sorted[~product_data_sorted['promotion']]
    
    if len(product_data_regular) > 10:
        price_changes = product_data_regular['price'].pct_change().dropna()
        sales_changes = product_data_regular['sales_volume'].pct_change().dropna()
        
        # 计算弹性
        valid_pairs = price_changes.index.intersection(sales_changes.index)
        if len(valid_pairs) > 0:
            elasticity_estimates = sales_changes[valid_pairs] / price_changes[valid_pairs].replace(0, np.nan)
            elasticity_estimates = elasticity_estimates.dropna()
            
            if len(elasticity_estimates) > 0:
                avg_elasticity = elasticity_estimates.mean()
                print(f"{product} 估计价格弹性: {avg_elasticity:.4f}")

# 3. 回归分析
print("\\n=== 3. 回归分析 ===")
for product in products:
    product_data = df[df['product_name'] == product]
    
    # 准备特征
    X = product_data[['price', 'promotion', 'advertising_spend', 'competitor_price']]
    X = pd.get_dummies(X, drop_first=True)
    y = product_data['sales_volume']
    
    # 拟合线性回归
    model = LinearRegression()
    model.fit(X, y)
    
    # 打印结果
    print(f"{product} 回归分析:")
    print(f"  截距: {model.intercept_:.4f}")
    for feature, coef in zip(X.columns, model.coef_):
        print(f"  {feature}: {coef:.4f}")
    print(f"  R²: {model.score(X, y):.4f}")

# 4. 促销效果分析
print("\\n=== 4. 促销效果分析 ===")
promotion_impact = df.groupby('product_name').agg({
    'sales_volume': [
        lambda x: x[df['promotion']].mean(),
        lambda x: x[~df['promotion']].mean()
    ]
}).round(2)
promotion_impact.columns = ['促销平均销量', '非促销平均销量']
promotion_impact['销量提升率'] = (promotion_impact['促销平均销量'] - promotion_impact['非促销平均销量']) / promotion_impact['非促销平均销量'] * 100
print("促销效果:")
print(promotion_impact)

# 5. 价格优化
print("\\n=== 5. 价格优化 ===")
for product in products:
    product_data = df[df['product_name'] == product]
    base_price = base_prices[products.index(product)]
    elasticity = price_elasticities[products.index(product)]
    
    # 收入 = 价格 * 销量
    # 销量 = 基准销量 * (1 + 弹性 * 价格变化百分比)
    # 收入 = 价格 * 基准销量 * (1 + 弹性 * (价格 - 基准价格)/基准价格)
    # 求导找到最优价格
    optimal_price = base_price * (1 - 1 / elasticity)
    
    # 计算当前收入
    current_revenue = (product_data['price'] * product_data['sales_volume']).mean()
    
    # 计算最优价格下的预计收入
    price_change = (optimal_price - base_price) / base_price
    sales_change = elasticity * price_change
    optimal_sales = base_sales[products.index(product)] * (1 + sales_change)
    optimal_revenue = optimal_price * optimal_sales
    
    print(f"{product}:")
    print(f"  基准价格: {base_price:.2f}")
    print(f"  价格弹性: {elasticity:.4f}")
    print(f"  最优价格: {optimal_price:.2f}")
    print(f"  当前平均收入: {current_revenue:.2f}")
    print(f"  预计最优收入: {optimal_revenue:.2f}")

# 6. 分析结论
print("\\n=== 6. 分析结论 ===")
print("1. 价格弹性分析显示不同产品的价格敏感度不同")
print("2. 促销对销量有明显的提升作用")
print("3. 广告支出和竞争对手价格也影响销量")
print("4. 建议基于价格弹性优化产品定价")
print("5. 设计有效的促销策略，提高收入和利润")
`,
