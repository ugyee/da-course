    codeTemplate: `import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
from sklearn.decomposition import FactorAnalysis
from sklearn.preprocessing import StandardScaler

# 设置中文字体
plt.rcParams['font.sans-serif'] = ['SimHei', 'WenQuanYi Micro Hei']
plt.rcParams['axes.unicode_minus'] = False

# 模拟市场调研数据
np.random.seed(42)
n_respondents = 200

# 人口统计信息
ages = np.random.randint(18, 65, n_respondents)
genders = np.random.choice(['男', '女'], n_respondents)
incomes = np.random.randint(5000, 20000, n_respondents)
educations = np.random.choice(['高中', '本科', '硕士', '博士'], n_respondents, p=[0.2, 0.5, 0.25, 0.05])

# 产品相关信息（1-5分制）
product_awareness = np.random.randint(1, 6, n_respondents)
product_preference = np.random.randint(1, 6, n_respondents)
purchase_intention = np.random.randint(1, 6, n_respondents)
price_sensitivity = np.random.randint(1, 6, n_respondents)
brand_loyalty = np.random.randint(1, 6, n_respondents)

# 添加一些相关性
product_preference = np.clip(product_awareness + np.random.randint(-1, 2, n_respondents), 1, 5)
purchase_intention = np.clip(product_preference + np.random.randint(-1, 2, n_respondents), 1, 5)

# 创建数据集
df = pd.DataFrame({
    'respondent_id': [f'R{i:03d}' for i in range(1, n_respondents + 1)],
    'age': ages,
    'gender': genders,
    'income': incomes,
    'education': educations,
    'product_awareness': product_awareness,
    'product_preference': product_preference,
    'purchase_intention': purchase_intention,
    'price_sensitivity': price_sensitivity,
    'brand_loyalty': brand_loyalty
})

print("=== 数据基本信息 ===")
print(df.info())
print("\n数据前5行:")
print(df.head())

# 1. 描述性统计分析
print("\n=== 1. 描述性统计分析 ===")
print("人口统计信息:")
print(df[['age', 'income']].describe())

print("\n产品相关信息:")
print(df[['product_awareness', 'product_preference', 'purchase_intention', 'price_sensitivity', 'brand_loyalty']].describe())

# 2. 交叉分析
print("\n=== 2. 交叉分析 ===")
# 性别与购买意愿
print("性别与购买意愿:")
gender_purchase = pd.crosstab(df['gender'], df['purchase_intention'], normalize='index')
print(gender_purchase)

# 教育程度与产品偏好
print("\n教育程度与产品偏好:")
education_preference = pd.crosstab(df['education'], df['product_preference'], normalize='index')
print(education_preference)

# 年龄分组与购买意愿
print("\n年龄分组与购买意愿:")
df['age_group'] = pd.cut(df['age'], bins=[18, 30, 45, 65], labels=['18-30', '31-45', '46-65'])
age_purchase = pd.crosstab(df['age_group'], df['purchase_intention'], normalize='index')
print(age_purchase)

# 3. 相关性分析
print("\n=== 3. 相关性分析 ===")
numeric_cols = ['age', 'income', 'product_awareness', 'product_preference', 'purchase_intention', 'price_sensitivity', 'brand_loyalty']
corr_matrix = df[numeric_cols].corr()

print("相关性矩阵:")
print(corr_matrix)

# 与购买意愿的相关性
print("\n与购买意愿的相关性:")
purchase_corr = corr_matrix['purchase_intention'].sort_values(ascending=False)
print(purchase_corr)

# 4. 因子分析
print("\n=== 4. 因子分析 ===")
# 选择要分析的变量
analysis_vars = ['product_awareness', 'product_preference', 'purchase_intention', 'price_sensitivity', 'brand_loyalty']

# 标准化数据
scaler = StandardScaler()
data_scaled = scaler.fit_transform(df[analysis_vars])

# 进行因子分析
fa = FactorAnalysis(n_components=2, random_state=42)
fa_result = fa.fit_transform(data_scaled)

# 添加因子得分到数据集
df['factor1'] = fa_result[:, 0]
df['factor2'] = fa_result[:, 1]

print("因子载荷矩阵:")
loadings = pd.DataFrame(fa.components_.T, index=analysis_vars, columns=['Factor1', 'Factor2'])
print(loadings)

print("\n因子解释方差:")
explained_variance = fa.explained_variance_ratio_
print(f"Factor1: {explained_variance[0]:.4f}")
print(f"Factor2: {explained_variance[1]:.4f}")
print(f"累计解释方差: {sum(explained_variance):.4f}")

# 5. 可视化分析
print("\n=== 5. 可视化分析 ===")
print("已生成以下图表:")
print("1. 购买意愿分布柱状图")
print("2. 性别与购买意愿对比柱状图")
print("3. 教育程度与产品偏好热力图")
print("4. 相关性热力图")
print("5. 因子分析散点图")

# 6. 消费者画像分析
